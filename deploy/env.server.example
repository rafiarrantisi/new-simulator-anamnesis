# ── backend/.env untuk SERVER (EC2). Salin ke backend/.env lalu isi. ──
# JANGAN commit file backend/.env (sudah di-gitignore).

# Lingkungan: 'dev' = prod-guard hanya WARN (boleh sqlite). 'prod' = TOLAK
# start bila sqlite/secret lemah. Demo single-box → pakai dev.
ENV=dev

# Auth: WAJIB ganti dgn acak kuat (≥32 byte). Generate:
#   openssl rand -hex 32
JWT_SECRET=GANTI_DENGAN_HASIL_openssl_rand_hex_32

# Token akses default 15 menit (frontend auto re-auth). Untuk demo nyaman,
# perpanjang biar dokter tak sering ke-logout:
ACCESS_TOKEN_MINUTES=720

# DB: SQLite di disk EC2 (persisten di EBS). Cukup untuk demo 1 dokter.
# (Kalau mau Postgres: ganti ke postgresql+psycopg2://... lalu `alembic
#  upgrade head` — minta bantuan asisten.)
DATABASE_URL=sqlite:////opt/ophtha/backend/ophtha_prod.db

# CORS: frontend di domain sama (nginx) → sebenarnya tak perlu, tapi isi
# untuk aman. Ganti SUBDOMAIN.
CORS_ORIGINS=["https://SUBDOMAIN.duckdns.org"]

# ── LLM (OpenRouter) — WAJIB diisi, sumber jawaban pasien & penilaian ──
LLM_PROVIDER=openrouter
LLM_API_KEY=GANTI_DENGAN_KEY_OPENROUTER_KAMU
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-v4-flash
LLM_JUDGE_MODEL=deepseek/deepseek-v4-flash

# ── STT/TTS (opsional; kosongkan kalau tak pakai suara) ──
# STT_BASE_URL=https://api.groq.com/openai/v1
# STT_API_KEY=
# TTS_API_KEY=

# ── Developer Dashboard (v0.15.0; opsional, kosongkan kalau tak perlu) ──
# Saat startup, lifespan() auto-seed user ini dgn role='admin' bila belum
# ada. Idempoten — bila user ada tapi role!=admin, log warning & TIDAK
# auto-promote (safety). Generate hash:
#   cd backend && .venv/bin/python -m scripts.hash_admin_password
# ADMIN_EMAIL=admin@your-domain.com
# ADMIN_PASSWORD_HASH=$2b$12$...

# Upload dir utk foto mata (dashboard). Default /opt/ophtha/uploads.
# UPLOAD_DIR=/opt/ophtha/uploads
