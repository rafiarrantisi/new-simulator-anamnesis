# Salin ke .env dan sesuaikan. JANGAN commit .env.
ENV=dev

# Dev: sqlite (runnable tanpa Docker). Prod (kontrak §7): PostgreSQL, mis.
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/ophtha
DATABASE_URL=sqlite:///./ophtha_dev.db

# WAJIB override di prod: secret ACAK >=32 byte. Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# ENV=prod|staging + JWT_SECRET lemah → app TOLAK start (prod-guard v0.9.0).
JWT_SECRET=dev-only-change-me
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# Prod: WAJIB origin spesifik (jangan "*").
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
DEFAULT_INSTITUTION_ID=default

# Rate limiting (in-memory; Redis = scale, ditunda)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH=20
RATE_LIMIT_AI=30
RATE_LIMIT_WINDOW_SEC=60

# ⚠️ KEAMANAN: semua *_API_KEY di .env. JANGAN commit. Bila pernah
# ter-share/bocor → ROTATE di dashboard provider (OpenRouter/Groq/
# ElevenLabs). Prod: pakai secrets manager, bukan .env mentah.

# RAG infra (Fase 3)
QDRANT_URL=http://localhost:6333
EMBED_MODEL=intfloat/multilingual-e5-large

# ── LLM (kontrak §9 K2). Kosongkan LLM_API_KEY → StubLlmClient. ──
# JANGAN commit .env berisi key asli.
LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
# Model persona (kuat — patuh answer-restraint). Contoh OpenRouter:
#   anthropic/claude-3.5-sonnet · openai/gpt-4o · google/gemini-pro-1.5
LLM_MODEL=anthropic/claude-3.5-sonnet
# Model judge (lebih murah, rag-plan §9.1)
LLM_JUDGE_MODEL=openai/gpt-4o-mini
# Opsional atribusi OpenRouter
LLM_SITE_URL=
LLM_APP_TITLE=OphthaSim

# Korpus kasus markdown (default: ../data-kasus)
# CASES_DIR=
